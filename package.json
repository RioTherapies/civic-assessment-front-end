{
  "name": "rio-civic-assessment",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @rio/civic-assessment && npm run build -w @rio/civic-assessment-web",
    "dev": "npm run dev -w @rio/civic-assessment-web",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "deploy": "bash scripts/deploy.sh --branch=main",
    "deploy:preview": "bash scripts/deploy.sh",
    "postinstall": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1",
    "wrangler": "^4.105.0"
  }
}
